# ============================================================
# World Cup 2026 Hub — environment variables
# ------------------------------------------------------------
# Copy this file to ".env.local" for local dev (`vercel dev`), and
# add the SAME keys in Vercel → Project → Settings → Environment Variables
# for production. NEVER commit real keys — .env* is gitignored.
# Only keys read by the serverless functions in /api need to live here.
# ============================================================

# ── News headlines ──────────────────────────────────────────
# Used by /api/news.js. Free tier: https://gnews.io
GNEWS_KEY=

# ── Live scores / fixtures / standings ──────────────────────
# Pick ONE provider, then wire /api/matches.js to it (ask Claude to scaffold).
#
# Option A — football-data.org (free tier; sends key as header X-Auth-Token)
#   https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=
#
# Option B — API-Football / api-sports.io (broader coverage, free tier) ← ACTIVE
#   https://www.api-football.com/  |  endpoint: v3.football.api-sports.io
#   Key sent as header: x-apisports-key   |  100 req/day free
#   /api/matches.js uses this key.  Cache: s-maxage=300 (5 min) to stay in quota.
API_FOOTBALL_KEY=

# ── Supabase (Meet Rooms realtime + Bracket auth) ───────────
# The ANON key is public by design and already lives in js/supabase-client.js
# — it is safe to expose and does NOT belong here.
# Only add the SERVICE-ROLE key if/when you build a server-side cron or admin
# task (e.g. an /api job that writes results). It bypasses RLS — keep it
# server-side only, NEVER in any js/* file shipped to the browser.
SUPABASE_URL=https://yqwmiffmwbdouxfkgbqa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
